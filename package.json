{
  "name": "ai_mock_project",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e:gate-disabled",
    "test:e2e:gate-active": "SAA_LAUNCH_AT=2099-12-31T00:00:00Z SAA_EVENT_START_AT=2099-12-31T00:00:00Z playwright test tests/e2e/prelaunch/gate-active",
    "test:e2e:gate-disabled": "SAA_LAUNCH_AT=2000-01-01T00:00:00Z SAA_EVENT_START_AT=2099-12-31T00:00:00Z playwright test --grep-invert \"Prelaunch gate-active\"",
    "test:e2e:ui": "playwright test --ui",
    "lighthouse:login": "node scripts/lighthouse-login.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "tsx prisma/seed.ts",
    "db:test:reset": "DATABASE_URL=$DATABASE_URL_TEST prisma migrate reset --force --skip-seed"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/client": "^6.19.3",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "jsdom": "^29.1.1",
    "lighthouse": "^12.8.2",
    "playwright-lighthouse": "^4.0.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
