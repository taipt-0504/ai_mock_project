# SAA 2025 — Environment template. Copy to `.env.local` and populate real values.
#   $ cp .env.example .env.local

# ----- Database -----------------------------------------------------------
# Connection strings for the dev DB (used by Next.js + Prisma migrate) and
# the dedicated test DB (used by Vitest globalSetup via `npm run db:test:reset`).
# When using `docker compose up db`, the defaults below match docker-compose.yml.
DATABASE_URL="postgresql://saa2025:saa2025@localhost:5432/saa2025?schema=public"
DATABASE_URL_TEST="postgresql://saa2025:saa2025@localhost:5432/saa2025_test?schema=public"

# ----- Auth.js (NextAuth) -------------------------------------------------
# Generate AUTH_SECRET locally with:
#   $ openssl rand -base64 32
# DO NOT commit a real secret. The value below is a placeholder so the build
# passes — replace it before running the dev server against real Google.
AUTH_SECRET="REPLACE_ME_WITH_OPENSSL_RAND_BASE64_32"

# ----- Google OAuth client ------------------------------------------------
# Provision via Google Cloud Console (see docs/auth-setup.md). Authorized
# redirect URI for dev: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="REPLACE_WITH_GOOGLE_OAUTH_CLIENT_ID"
AUTH_GOOGLE_SECRET="REPLACE_WITH_GOOGLE_OAUTH_CLIENT_SECRET"

# ----- Auth.js host trust (production only) -------------------------------
# Set to "true" in environments behind a proxy (Vercel auto-detects). Leave
# unset locally.
# AUTH_TRUST_HOST=

# ----- Runtime ------------------------------------------------------------
NODE_ENV="development"

# ----- Homepage SAA — event countdown -------------------------------------
# ISO-8601 datetime with timezone. Drives the Hero countdown on `/`. Leave
# unset (or malformed) to fall back to "-- / -- / --" + "Coming soon" — the
# page won't crash. Replace the placeholder with the real program target
# before deployment.
SAA_EVENT_START_AT="2025-12-31T18:30:00+07:00"

# ----- SAA pre-launch gate ------------------------------------------------
# ISO-8601 datetime with timezone. Drives the global pre-launch gate in
# `proxy.ts`. Required in EVERY environment (production, staging, dev,
# test, CI) — the proxy fails CLOSED when this is unset / empty /
# malformed (every non-whitelisted request 307s to `/coming-soon`). See
# spec FR-009 + plan.md for the threat model.
#
# Set to a PAST timestamp to disable the gate (normal local dev + the
# `gate-disabled` CI cell — `npm run test:e2e:gate-disabled`):
SAA_LAUNCH_AT="2025-01-01T00:00:00+07:00"
# Set to a FUTURE timestamp to test the prelaunch surface (the
# `gate-active` CI cell — `npm run test:e2e:gate-active`):
# SAA_LAUNCH_AT="2099-12-31T00:00:00+07:00"
