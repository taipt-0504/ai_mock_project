# Vitest auto-loads this file via Vite `loadEnv` (vitest.config.ts).
# Committed with safe placeholders so `npm run test` works after
#   docker compose up -d db && npm run db:test:reset
# with no further setup. Override per-developer in `.env.test.local`
# (gitignored). Shell-provided vars still win.

# ----- Database (test schema) ---------------------------------------------
# vitest.setup.ts mirrors DATABASE_URL_TEST onto DATABASE_URL so Prisma
# always points at the dedicated test DB during the suite.
DATABASE_URL="postgresql://saa2025:saa2025@localhost:5432/saa2025_test?schema=public"
DATABASE_URL_TEST="postgresql://saa2025:saa2025@localhost:5432/saa2025_test?schema=public"

# ----- Auth.js placeholders ------------------------------------------------
# Tests stub OAuth — these values are never exercised against Google.
AUTH_SECRET="test-only-placeholder-secret-32-bytes-min"
AUTH_GOOGLE_ID="test-placeholder-id"
AUTH_GOOGLE_SECRET="test-placeholder-secret"
AUTH_TRUST_HOST="true"

# ----- SAA pre-launch gate -------------------------------------------------
# Past timestamp = gate disabled, the default for the regression suite.
# Tests that need gate-active opt in via vi.stubEnv + vi.resetModules.
SAA_LAUNCH_AT="2000-01-01T00:00:00Z"

# ----- Homepage SAA — event countdown --------------------------------------
SAA_EVENT_START_AT="2025-12-31T18:30:00+07:00"
